NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173,http://localhost:5174
# Supabase pooled/session connection for runtime
DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres
# Supabase direct connection for Prisma CLI commands
DIRECT_URL=postgresql://postgres:your-password@db.project-ref.supabase.co:5432/postgres
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=usd
